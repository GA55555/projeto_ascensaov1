# Dependências
node_modules/

# Variáveis de ambiente
.env

# ==========================================
# UPLOADS DE USUÁRIOS (Proteção Automática)
# ==========================================
# Ignora tudo dentro de uploads e qualquer subpasta futura
public/uploads/**/*

# Mas mantém a estrutura das pastas lendo os arquivos .gitkeep
!public/uploads/**/.gitkeep

# Logs
*.log
npm-debug.log*

# ==========================================
# Oráculo Service (Python) — segredos e artefactos NUNCA vão para o Git
# ==========================================
# (venv real é 'venv/'; '.venv/' incluído por segurança)
oraculo_service/venv/
oraculo_service/.venv/
oraculo_service/chroma_data/
oraculo_service/.env
oraculo_service/__pycache__/