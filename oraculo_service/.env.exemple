# ==========================================================
# Oráculo Service (.env) — microsserviço RAG, escuta só em 127.0.0.1
# Copie para .env e preencha. NUNCA versionar o .env real.
# Referência: oraculo.md §6 (segredos do servidor, não-DDL).
# ==========================================================

# Porta interna do FastAPI/uvicorn (localhost-only).
ORACULO_PORT=8000

# Segredo do header interno Node <-> Python (X-Oraculo-Secret).
# Impede que outro processo local chame as rotas (Regra 6.4).
ORACULO_SHARED_SECRET=troque-por-um-segredo-forte

# Chave OpenAI do PROJETO para embeddings (text-embedding-3-small).
# NÃO é BYOK — o custo (centavos) fica com o dono do servidor (§4.4 / §7.1).
# Usada por /upsert e pelo retrieval do /consultar.
OPENAI_EMBEDDINGS_KEY=sk-...

# OBS: a chave de GERAÇÃO (BYOK do Narrador, padrão DeepSeek) NÃO mora aqui.
# Ela chega cifrada do Postgres, é decifrada pelo Node e enviada ao Python
# apenas no corpo da chamada /consultar (api_key_llm / base_url_llm / model_llm).
